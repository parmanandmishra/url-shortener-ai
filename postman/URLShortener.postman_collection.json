      "name": "Positive Tests",
      "item": [
        {
          "name": "Create Short URL - Valid HTTPS",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"originalUrl\": \"https://github.com/parmanandmishra/url-shortener-ai\"\n}"
            },
            "url": "{{baseUrl}}/api/urls/shorten"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('HTTP status is 201', function () { pm.response.to.have.status(201); });",
                  "pm.test('Response time is below 2000 ms', function () { pm.expect(pm.response.responseTime).to.be.below(2000); });",
                  "pm.test('Response body is valid JSON', function () { pm.expect(function () { pm.response.json(); }).to.not.throw(); });",
                  "const json = pm.response.json();",
                  "pm.test('Response contains shortCode', function () { pm.expect(json).to.have.property('shortCode'); });",
                  "pm.test('shortCode is 6 characters', function () { pm.expect(json.shortCode).to.have.lengthOf(6); });",
                  "pm.test('Response contains originalUrl', function () { pm.expect(json.originalUrl).to.eql('https://github.com/parmanandmishra/url-shortener-ai'); });",
                  "pm.collectionVariables.set('shortCode', json.shortCode);",
                  "pm.collectionVariables.set('recordId', json.id);"
                ]
              }
            }
          ]
        },
